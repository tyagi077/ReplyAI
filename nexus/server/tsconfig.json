{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "nodenext",
    "outDir": "./dist",
    "rootDir": "./src",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "sourceMap": true,
    "inlineSources": true,

    "lib": ["ES2021", "DOM"]   // ✅ REQUIRED for fetch + FormData typings
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
